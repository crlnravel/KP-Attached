DEBUG=false
# When DEBUG=true, access requests are auto-approved locally and do not require remote auth URLs.

# Remote psychologist access-request endpoint.
# Example: https://attached.example.com/api/auth/access-request
ATTACHED_REMOTE_AUTH_REQUEST_URL=

# Remote approval-sync endpoint used during sign-in for pending accounts.
# Example: https://attached.example.com/api/auth/sign-in
ATTACHED_REMOTE_AUTH_SIGN_IN_URL=

# Optional timeout for remote approval requests in milliseconds.
ATTACHED_REMOTE_AUTH_TIMEOUT_MS=15000
